# =============================================================================
# SwissBuildingOS - Environment Variables
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# ---- PostgreSQL / PostGIS ----
POSTGRES_DB=swissbuildingos
POSTGRES_USER=swissbuildingos
POSTGRES_PASSWORD=swissbuildingos_dev_2024
DATABASE_URL=postgresql+asyncpg://swissbuildingos:swissbuildingos_dev_2024@postgres:5432/swissbuildingos

# ---- JWT Authentication ----
JWT_SECRET_KEY=dev-secret-key-change-in-production-abc123
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# ---- S3 / MinIO Object Storage ----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=swissbuildingos-documents

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]
