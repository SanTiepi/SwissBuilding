# SwissBuilding / BatiConnect — Production Environment
# Copy to .env.production and fill in real values

# === PostgreSQL (own instance, NOT shared with Batiscan) ===
POSTGRES_DB=swissbuildingos
POSTGRES_USER=swissbuildingos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://swissbuildingos:CHANGE_ME@postgres:5432/swissbuildingos

# === JWT ===
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# === Infomaniak S3 (own buckets, NOT shared with Batiscan) ===
S3_ENDPOINT=https://s3.pub1.infomaniak.cloud
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=swissbuilding-uploads
S3_REGION=us-east-1

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Bridge to Batiscan V4 (read-only) ===
BATISCAN_API_URL=https://app.batiscan.ch
BATISCAN_API_KEY=CHANGE_ME

# === AI Provider (optional) ===
OPENAI_API_KEY=

# === Logging ===
LOG_LEVEL=INFO
ENVIRONMENT=production
